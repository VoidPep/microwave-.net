<div class="card mb-4">
    <div class="card-header">
        <strong>Login</strong>
    </div>
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label for="authUsername" class="form-label">Usuário</label>
                <input type="text" class="form-control" id="authUsername" placeholder="Usuário" autocomplete="username" />
            </div>
            <div class="col-auto">
                <label for="authPassword" class="form-label">Senha</label>
                
                <input type="password" class="form-control" id="authPassword" placeholder="••••••" autocomplete="current-password" />
            </div>
            <div class="col-auto">
                <button type="button" id="btnLogin" class="btn btn-primary">Entrar</button>
            </div>
            <div class="col-auto">
                <button type="button" id="btnLogout" class="btn btn-primary">Sair</button>
            </div>
        </div>
        <div class="mt-2">
            <small id="authStatus" class="text-muted">Não autenticado. Faça login para usar o microondas.</small>
        </div>
    </div>
</div>
