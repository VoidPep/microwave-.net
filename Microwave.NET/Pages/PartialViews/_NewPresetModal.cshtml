<div class="modal fade" id="newPresetModal" tabindex="-1" role="dialog" aria-labelledby="newPresetModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="newPresetModalLabel">Criar Novo Programa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" />
            </div>
            <div class="modal-body">
                <form id="newPresetForm">
                    <div class="form-group">
                        <label for="presetName">Nome do Programa *</label>
                        <input type="text" class="form-control" id="presetName" required>
                    </div>
                    <div class="form-group">
                        <label for="presetPotencia">Potência (1-10) *</label>
                        <input type="number" class="form-control" id="presetPotencia" min="1" max="10" required>
                    </div>
                    <div class="form-group">
                        <label for="presetCaractere">Caractere de Aquecimento *</label>
                        <input type="text" class="form-control" id="presetCaractere" maxlength="1" required>
                        <small class="form-text text-muted">Um caractere único (não pode ser "." ou já utilizado)</small>
                    </div>
                    <div class="form-group">
                        <label for="presetTempo">Tempo (segundos) *</label>
                        <input type="number" class="form-control" id="presetTempo" min="1" required>
                    </div>
                    <div class="form-group">
                        <label for="presetInstrucoes">Instruções de Uso</label>
                        <textarea class="form-control" id="presetInstrucoes" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSavePreset">Salvar</button>
            </div>
        </div>
    </div>
</div>

